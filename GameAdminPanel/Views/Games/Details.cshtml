@model GameAdminPanel.Models.Game

@{
    ViewData["Title"] = "Детали игры";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">ℹ️ Детали игры</h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">ID:</label>
                        <p class="form-control-plaintext">@Model.Id</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Название:</label>
                        <p class="form-control-plaintext">@Model.Title</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание:</label>
                        <div class="border rounded p-3 bg-light">
                            @Model.Description
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Дата релиза:</label>
                        <p class="form-control-plaintext">@Model.ReleaseDate.ToString("dd.MM.yyyy")</p>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>